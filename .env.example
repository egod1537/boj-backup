# BOJ backup example environment file.
# Copy this file to `.env` and fill in the values you want to use.

# Preferred when BOJ shows reCAPTCHA on /login.
# Paste the full cookie header fragment for the OnlineJudge cookie.
BOJ_COOKIE=OnlineJudge=your_session_cookie

# Optional legacy credential flow.
# Only use this when BOJ_ID/BOJ_PW login works for your account.
# BOJ_ID=myhandle
# BOJ_PW=mypassword

# Optional request delay in milliseconds. Minimum is 2000.
BOJ_DELAY_MS=3000

# Notes:
# - On Windows, if BOJ_COOKIE is empty, the app will also try to reuse a logged-in
#   Chrome/Edge/Brave session for the current OS user.
# - If the browser is running and locks the cookie DB, close the browser first or
#   set BOJ_COOKIE manually in `.env`.
